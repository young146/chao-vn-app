rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 관리자 이메일 체크 함수
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'info@chaovietnam.co.kr' ||
        request.auth.token.email == 'younghan146@gmail.com'
      );
    }

    // ✅ 이웃사업 이미지 (관리자만 업로드, 누구나 열람)
    match /neighbor_businesses/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ✅ 앱에서 업로드하는 이미지 (기존)
    match /items/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /jobs/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /realestate/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ✅ 카카오 웹폼에서 업로드하는 이미지 (익명 허용)
    match /form_uploads/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    match /items-web/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    match /realestate-web/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    match /jobs-web/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }

    // ✅ 프로필 이미지 업로드 (로그인 사용자만)
    match /profileImages/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ✅ 중개인 프로필 이미지 (로그인 사용자만)
    match /agents/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 기본 거부
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
