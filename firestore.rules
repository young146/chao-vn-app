rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 관리자 이메일 체크 함수
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'info@chaovietnam.co.kr' ||
        request.auth.token.email == 'younghan146@gmail.com'
      );
    }

    // 🚫 영구 제명(블랙리스트) 체크 함수
    // bannedUsers/{이메일} 문서가 존재하면 차단된 회원.
    // 클라이언트를 조작해도 이 규칙은 서버에서 강제되므로 우회 불가.
    // (카카오는 합성 이메일 kakao_{id}@chaovietnam.co.kr 이 토큰 이메일)
    function isBanned() {
      return request.auth != null
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/bannedUsers/$(request.auth.token.email));
    }

    // 차단되지 않은 정상 로그인 사용자
    function isActiveUser() {
      return request.auth != null && !isBanned();
    }

    // ========================================
    // 🚫 bannedUsers (블랙리스트) 컬렉션
    // - get: 본인 차단여부만 확인 가능 (목록 열람 불가 → 명단 유출 방지)
    // - list/write: 관리자만
    // - (규칙 내부 isBanned()의 exists()는 읽기권한과 무관하게 동작)
    // ========================================
    match /bannedUsers/{banKey} {
      // 본인은 자기 차단여부 확인 가능 / 관리자는 누구든 확인·목록·등록·해제 가능
      allow get: if isAdmin() || (request.auth != null && request.auth.token.email == banKey);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ========================================
    // 📦 XinChaoDanggn (나눔/당근) 컬렉션
    // ========================================
    match /XinChaoDanggn/{docId} {
      allow read: if true;
      allow create: if (isActiveUser()) || request.resource.data.source == 'web';
      allow update: if (request.auth != null && !isBanned() &&
        (request.auth.uid == resource.data.userId || isAdmin()))
        || resource.data.source == 'web';
      allow delete: if request.auth != null &&
        (request.auth.uid == resource.data.userId || isAdmin());
    }

    // ========================================
    // 💼 Jobs (구인구직) 컬렉션
    // ========================================
    match /Jobs/{jobId} {
      allow read: if true;
      allow create: if (isActiveUser()) || request.resource.data.source == 'web';
      allow update: if (request.auth != null && !isBanned() &&
        (request.auth.uid == resource.data.userId || isAdmin()))
        || resource.data.source == 'web';
      allow delete: if request.auth != null &&
        (request.auth.uid == resource.data.userId || isAdmin());
    }

    // ========================================
    // 👤 candidates (구직자) 컬렉션
    // ========================================
    match /candidates/{docId} {
      allow read: if true;
      allow create: if (isActiveUser()) || request.resource.data.source == 'web';
      allow update: if (request.auth != null && !isBanned() &&
        (request.auth.uid == resource.data.userId || isAdmin()))
        || resource.data.source == 'web';
      allow delete: if request.auth != null &&
        (request.auth.uid == resource.data.userId || isAdmin());
    }

    // ========================================
    // 🏠 RealEstate (부동산) 컬렉션
    // ========================================
    match /RealEstate/{itemId} {
      allow read: if true;
      allow create: if (isActiveUser()) || request.resource.data.source == 'web';
      allow update: if (request.auth != null && !isBanned() &&
        (request.auth.uid == resource.data.userId || isAdmin()))
        || resource.data.source == 'web';
      allow delete: if request.auth != null &&
        (request.auth.uid == resource.data.userId || isAdmin());
    }

    // ========================================
    // 👤 사용자 프로필
    // ========================================
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // ========================================
    // ⭐ 리뷰
    // ========================================
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isActiveUser();
    }

    // ========================================
    // ❤️ 찜 (즐겨찾기)
    // ========================================
    match /favorites/{favoriteId} {
      allow read, write: if request.auth != null;
    }

    // ========================================
    // 🔖 북마크
    // ========================================
    match /bookmarks/{bookmarkId} {
      allow read, write: if request.auth != null;
    }

    // ========================================
    // 💬 채팅방 및 메시지
    // ========================================
    match /chatRooms/{roomId} {
      allow read: if request.auth != null;
      allow write: if isActiveUser();

      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow write: if isActiveUser();
      }
    }

    // ========================================
    // 💭 댓글
    // ========================================
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && !isBanned()
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && !isBanned()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.articleId == resource.data.articleId
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ========================================
    // 🔔 알림
    // ========================================
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null;
    }

    // ========================================
    // ⚙️ 알림 설정
    // ========================================
    match /notificationSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ========================================
    // 📋 카카오톡 웹폼 등록 (로그인 불필요)
    // ========================================
    match /form_items/{docId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // ========================================
    // 💼 CRM 영업 파이프라인 (로그인 불필요 내부 도구)
    // ========================================
    match /xinchao_crm/{docId} {
      allow read, write: if true;
    }

    // ========================================
    // 📢 ads (광고 배너) 컬렉션
    // ========================================
    match /ads/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ========================================
    // 🚀 app_ads (앱 자체광고 관리) 컬렉션
    // daily-news-final admin에서 관리, 앱에서 읽기
    // ========================================
    match /app_ads/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ========================================
    // 🏢 Agents (부동산 중개인) 컬렉션
    // ========================================
    match /Agents/{agentId} {
      // 누구나 열람 가능 (매물 상세에서 표시)
      allow read: if true;
      // 차단되지 않은 로그인 사용자만 등록
      allow create: if isActiveUser();
      // 본인 또는 관리자만 수정/삭제
      allow update: if request.auth != null && !isBanned() &&
        (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if request.auth != null &&
        (request.auth.uid == resource.data.userId || isAdmin());
    }

    // ========================================
    // 🏪 NeighborBusinesses (이웃사업) 컬렉션
    // ========================================
    match /NeighborBusinesses/{docId} {
      // 누구나 열람 가능 (active + approved 업소만)
      allow read: if true;
      // 등록/수정/삭제는 관리자만
      allow create, update, delete: if isAdmin();
    }

    // ========================================
    // 📢 Announcements (공지 배너) 컬렉션
    // ========================================
    match /Announcements/{docId} {
      // 누구나 열람 가능 (active 공지만 앱에서 필터링)
      allow read: if true;
      // 등록/수정/삭제는 관리자만
      allow create, update, delete: if isAdmin();
    }

    // ========================================
    // 📣 announcements (푸시 공지 + 댓글 스레드)
    // Cloud Function(Admin SDK)이 문서 생성 → 규칙 불필요
    // 앱: 모든 사용자 읽기, 인증 사용자 댓글 쓰기
    // ========================================
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 500;
        allow delete: if request.auth != null
          && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    // ========================================
    // 📇 deviceTokens (기기 푸시 토큰 명단 — 로그인 불필요)
    // 앱 설치자 전원(비로그인 포함)이 자기 기기 토큰을 등록.
    // 읽기는 토큰 보호 위해 관리자만 (서버는 Admin SDK라 규칙 우회).
    // ========================================
    match /deviceTokens/{docId} {
      allow read: if isAdmin();
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // ========================================
    // 🚫 기본 거부 (위에서 정의되지 않은 모든 문서)
    // ========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
